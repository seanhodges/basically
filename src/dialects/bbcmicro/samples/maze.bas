10 REM MAZE
20 MODE 7
30 DIM M$(21)
40 M$(1)="#######################################"
50 M$(2)="#       #                 #     #     #"
60 M$(3)="####### ### ########### # # # ### ### #"
70 M$(4)="#     #   #   #       # #   # #   #   #"
80 M$(5)="# ### ### ##### ##### # ####### ### # #"
90 M$(6)="#   #   # #     #   # # #         # # #"
100 M$(7)="##### ### # ##### ### # # ######### # #"
110 M$(8)="#     #   # #   #     #   #       # # #"
120 M$(9)="# ##### ### # # # ##### ### ##### # # #"
130 M$(10)="# #   #     # # # #   # # # #     # # #"
140 M$(11)="# # # ####### # # # ### # # ##### # # #"
150 M$(12)="#   #         # # #     # #     #   # #"
160 M$(13)="# ############# # # ##### ##### ##### #"
170 M$(14)="# #     #       # #   #   #     #   # #"
180 M$(15)="# # ### # ### ### ### # # # ##### ### #"
190 M$(16)="# #   #   #   #   #     # # #   #   # #"
200 M$(17)="# ### ######### ########### # ### # # #"
210 M$(18)="#   #           #     #   # # #   #   #"
220 M$(19)="### ############# ### # # # # # #######"
230 M$(20)="#                 #     #   #         E"
240 M$(21)="#######################################"
250 FOR R%=1 TO 21:PROCrow(R%):NEXT
260 PRINT TAB(0,22);"REACH E TO WIN"
270 PRINT TAB(0,23);"z x k m to move"
280 X%=2:Y%=2:F%=0:PROCplayer
290 REPEAT
300 K$=INKEY$(0)
310 U%=Y%:V%=X%
320 IF K$="Z" THEN V%=X%-1
330 IF K$="X" THEN V%=X%+1
340 IF K$="K" THEN U%=Y%-1
350 IF K$="M" THEN U%=Y%+1
360 IF (V%<>X% OR U%<>Y%) AND MID$(M$(U%),V%,1)<>"#" THEN VDU 31,X%,Y%,32:X%=V%:Y%=U%:PROCplayer
370 UNTIL MID$(M$(Y%),X%,1)="E"
380 PRINT TAB(0,24);CHR$(130);CHR$(136);"YOU ESCAPED!"
390 END
400 DEF PROCrow(R%)
410 LOCAL I%,L$
420 L$=""
430 FOR I%=1 TO 39
440 IF MID$(M$(R%),I%,1)="#" THEN L$=L$+CHR$(255) ELSE L$=L$+" "
450 NEXT
460 VDU 31,0,R%,150:PRINT L$;
470 IF INSTR(M$(R%),"E") THEN VDU 31,INSTR(M$(R%),"E")-2,R%,146,136,255
480 ENDPROC
490 DEF PROCplayer
500 F%=1-F%
510 VDU 31,X%,Y%,185+45*F%
520 ENDPROC
