10 REM DODGER - AVOID THE BLOCKS
20 MODE 1
30 PX=580:S%=0
40 REPEAT
50 BX=RND(1152):BY=960:C%=RND(3)
60 REPEAT
70 K$=INKEY$(0)
80 IF K$="Z" AND PX>0 THEN GCOL 0,0:PROCblk(PX,40,120,32):PX=PX-48
90 IF K$="X" AND PX<1160 THEN GCOL 0,0:PROCblk(PX,40,120,32):PX=PX+48
100 GCOL 0,3:PROCblk(PX,40,120,32)
110 GCOL 0,0:PROCblk(BX,BY,64,64)
120 BY=BY-32
130 GCOL 0,C%:PROCblk(BX,BY,64,64)
140 T%=TIME:REPEAT UNTIL TIME>T%+1
150 UNTIL BY<72
160 IF BX+64>=PX AND BX<=PX+120 THEN 200
170 GCOL 0,0:PROCblk(BX,BY,64,64)
180 S%=S%+1
190 UNTIL FALSE
200 GCOL 0,1:PRINT TAB(14,16);"CRASHED"
210 PRINT TAB(13,18);"SCORE ";S%
220 END
230 DEF PROCblk(x,y,w,h)
240 MOVE x,y:MOVE x+w,y:PLOT 85,x,y+h:PLOT 85,x+w,y+h
250 ENDPROC
