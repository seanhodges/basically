10 REM BREAKOUT
20 MODE 1
30 DIM B%(9,3)
40 NB%=40
50 FOR C%=0 TO 9
60 FOR R%=0 TO 3
70 B%(C%,R%)=1
80 GCOL 0,(R% MOD 3)+1
90 PROCblk(C%*128,820+R%*48,116,40)
100 NEXT
110 NEXT
120 PX=520:BX=632:BY=200:VX=24:VY=24:S%=0
130 GCOL 0,3:PROCblk(PX,40,240,24)
135 PRINT TAB(0,31);"Z X TO MOVE";
140 REPEAT
150 K$=INKEY$(0)
160 IF (K$="Z" OR K$="z") AND PX>0 THEN GCOL 0,0:PROCblk(PX,40,240,24):PX=PX-56:GCOL 0,3:PROCblk(PX,40,240,24)
170 IF (K$="X" OR K$="x") AND PX<1040 THEN GCOL 0,0:PROCblk(PX,40,240,24):PX=PX+56:GCOL 0,3:PROCblk(PX,40,240,24)
180 GCOL 0,0:PROCblk(BX,BY,32,32)
190 BX=BX+VX:BY=BY+VY
200 IF BX<0 OR BX>1248 THEN VX=-VX
210 IF BY+32>1020 THEN VY=-ABS(VY)
220 IF BY<72 AND BX+32>=PX AND BX<=PX+240 THEN VY=ABS(VY)
230 PROChit
240 GCOL 0,1:PROCblk(BX,BY,32,32)
250 T%=TIME:REPEAT UNTIL TIME>T%+1
260 UNTIL BY<0 OR NB%=0
270 GCOL 0,3
280 IF NB%=0 THEN PRINT TAB(14,16);"YOU WIN" ELSE PRINT TAB(13,16);"GAME OVER"
290 PRINT TAB(13,18);"SCORE ";S%
300 END
310 DEF PROCblk(x,y,w,h)
320 MOVE x,y:MOVE x+w,y:PLOT 85,x,y+h:PLOT 85,x+w,y+h
330 ENDPROC
340 DEF PROChit
350 LOCAL cx,cy
360 cx=BX+16:cy=BY+16
370 IF cy<820 OR cy>1004 THEN ENDPROC
380 C%=INT(cx/128):R%=INT((cy-820)/48)
390 IF C%<0 OR C%>9 OR R%<0 OR R%>3 THEN ENDPROC
400 IF cx-C%*128>116 OR cy-820-R%*48>40 THEN ENDPROC
410 IF B%(C%,R%)=0 THEN ENDPROC
420 B%(C%,R%)=0:NB%=NB%-1:S%=S%+1:VY=-VY
430 GCOL 0,0:PROCblk(C%*128,820+R%*48,116,40)
440 ENDPROC
