10 REM BREAKOUT
20 MODE 1
30 PX=520:BX=640:BY=480:VX=24:VY=24:S%=0
40 FOR I%=0 TO 9
50 GCOL 0,(I% MOD 3)+1
60 PROCblk(I%*128,940,116,40)
70 NEXT
80 REPEAT
90 K$=INKEY$(0)
100 IF K$="Z" AND PX>0 THEN GCOL 0,0:PROCblk(PX,40,240,24):PX=PX-56
110 IF K$="X" AND PX<1040 THEN GCOL 0,0:PROCblk(PX,40,240,24):PX=PX+56
120 GCOL 0,3:PROCblk(PX,40,240,24)
130 GCOL 0,0:PROCblk(BX,BY,32,32)
140 BX=BX+VX:BY=BY+VY
150 IF BX<0 OR BX>1248 THEN VX=-VX
160 IF BY>880 THEN VY=-ABS(VY):S%=S%+1
170 IF BY<72 AND BX+32>=PX AND BX<=PX+240 THEN VY=ABS(VY)
180 GCOL 0,1:PROCblk(BX,BY,32,32)
190 T%=TIME:REPEAT UNTIL TIME>T%+1
200 UNTIL BY<0
210 GCOL 0,3:PRINT TAB(13,16);"GAME OVER"
220 PRINT TAB(13,18);"SCORE ";S%
230 END
240 DEF PROCblk(x,y,w,h)
250 MOVE x,y:MOVE x+w,y:PLOT 85,x,y+h:PLOT 85,x+w,y+h
260 ENDPROC
