10 REM BREAKOUT
20 MODE 1
30 COLOUR 2:PRINT TAB(16,4);"BREAKOUT"
40 COLOUR 3:PRINT TAB(13,12);"1. KEYBOARD"
50 PRINT TAB(13,14);"2. JOYSTICK"
60 COLOUR 1:SOUND 1,-15,89,4:SOUND 1,-15,101,4:SOUND 1,-15,117,4:SOUND 1,-15,149,8
70 M%=1
80 K$=GET$
90 IF K$="2" THEN M%=2
91 IF M%=1 THEN COLOUR 3:PRINT TAB(10,18);"PRESS SPACE TO START"
92 IF M%=2 THEN COLOUR 3:PRINT TAB(10,18);"PRESS FIRE TO START"
93 K$=INKEY$(0)
94 IF M%=1 AND K$<>" " THEN GOTO 93
95 IF M%=2 AND (ADVAL(0) AND 16)<>0 THEN GOTO 93
100 CLS
110 DIM B%(9,3)
120 NB%=40
130 FOR C%=0 TO 9
140 FOR R%=0 TO 3
150 B%(C%,R%)=1
160 GCOL 0,(R% MOD 3)+1
170 PROCblk(C%*128,820+R%*48,116,40)
180 NEXT
190 NEXT
200 PX=520:BX=632:BY=200:VX=24:VY=24:S%=0
210 GCOL 0,3:PROCblk(PX,40,240,24)
215 IF M%=1 THEN PRINT TAB(0,31);"Z X TO MOVE";
217 IF M%=2 THEN PRINT TAB(0,31);"JOYSTICK";
220 REPEAT
230 LF%=0:RT%=0
240 IF M%=1 THEN K$=INKEY$(0):IF K$="Z" OR K$="z" THEN LF%=1
250 IF M%=1 AND (K$="X" OR K$="x") THEN RT%=1
260 IF M%=2 AND ADVAL(1)>49152 THEN LF%=1
270 IF M%=2 AND ADVAL(1)<16384 THEN RT%=1
280 IF LF% AND PX>0 THEN GCOL 0,0:PROCblk(PX,40,240,24):PX=PX-56:GCOL 0,3:PROCblk(PX,40,240,24)
290 IF RT% AND PX<1040 THEN GCOL 0,0:PROCblk(PX,40,240,24):PX=PX+56:GCOL 0,3:PROCblk(PX,40,240,24)
300 GCOL 0,0:PROCblk(BX,BY,32,32)
310 BX=BX+VX:BY=BY+VY
320 IF BX<0 OR BX>1248 THEN VX=-VX:SOUND 1,-15,50,1
330 IF BY+32>1020 THEN VY=-ABS(VY):SOUND 1,-15,50,1
340 IF BY<72 AND BX+32>=PX AND BX<=PX+240 THEN VY=ABS(VY):SOUND 1,-15,50,1
350 PROChit
360 GCOL 0,1:PROCblk(BX,BY,32,32)
370 T%=TIME:REPEAT UNTIL TIME>T%+1
380 UNTIL BY<0 OR NB%=0
390 IF NB%>0 THEN FOR P%=200 TO 40 STEP -8:SOUND 1,-15,P%,1:NEXT
400 GCOL 0,3
410 IF NB%=0 THEN PRINT TAB(14,16);"YOU WIN" ELSE PRINT TAB(13,16);"GAME OVER"
420 PRINT TAB(13,18);"SCORE ";S%
430 END
440 DEF PROCblk(x,y,w,h)
450 MOVE x,y:MOVE x+w,y:PLOT 85,x,y+h:PLOT 85,x+w,y+h
460 ENDPROC
470 DEF PROChit
480 LOCAL cx,cy
490 cx=BX+16:cy=BY+16
500 IF cy<820 OR cy>1004 THEN ENDPROC
510 C%=INT(cx/128):R%=INT((cy-820)/48)
520 IF C%<0 OR C%>9 OR R%<0 OR R%>3 THEN ENDPROC
530 IF cx-C%*128>116 OR cy-820-R%*48>40 THEN ENDPROC
540 IF B%(C%,R%)=0 THEN ENDPROC
550 B%(C%,R%)=0:NB%=NB%-1:S%=S%+1:VY=-VY:SOUND 1,-15,180,1
560 GCOL 0,0:PROCblk(C%*128,820+R%*48,116,40)
570 ENDPROC
