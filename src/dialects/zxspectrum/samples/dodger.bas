10 REM DODGER - AVOID THE BLOCKS
20 BORDER 0: PAPER 0: INK 7: CLS
30 LET x=15: LET s=0
40 LET bx=INT (RND*32): LET by=0
50 LET k$=INKEY$
60 IF k$="5" AND x>0 THEN LET x=x-1
70 IF k$="8" AND x<31 THEN LET x=x+1
80 PRINT AT by,bx;" "
90 LET by=by+1
100 PRINT AT by,bx; INK 2;"█"
110 PRINT AT 21,0;"                                "
120 PRINT AT 21,x; INK 6;"▀"
130 IF by=21 AND bx=x THEN GO TO 170
140 IF by<21 THEN GO TO 50
150 PRINT AT by,bx;" ": LET s=s+1
160 GO TO 40
170 PRINT AT 10,10; FLASH 1;"CRASHED"
180 PRINT AT 12,12;"SCORE ";s
190 PAUSE 300
200 RUN
