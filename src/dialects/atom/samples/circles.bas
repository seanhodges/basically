10 REM CONCENTRIC CIRCLES - INTEGER MIDPOINT ALGORITHM
20 REM MOVE/DRAW NEED PLAIN VARS, SO EACH POINT IS PRECOMPUTED
30 CLEAR 4
40 FOR R=20 TO 80 STEP 20
50 P=0
60 Q=R
70 D=3-2*R
80 DO
90 A=128+P
100 B=128-P
110 C=96+Q
120 E=96-Q
130 F=128+Q
140 G=128-Q
150 H=96+P
160 I=96-P
170 MOVE A,C
180 DRAW A,C
190 MOVE B,C
200 DRAW B,C
210 MOVE A,E
220 DRAW A,E
230 MOVE B,E
240 DRAW B,E
250 MOVE F,H
260 DRAW F,H
270 MOVE G,H
280 DRAW G,H
290 MOVE F,I
300 DRAW F,I
310 MOVE G,I
320 DRAW G,I
330 S=D
340 IF S<0 THEN D=D+4*P+6
350 IF S>=0 THEN D=D+4*(P-Q)+10
360 IF S>=0 THEN Q=Q-1
370 P=P+1
380 UNTIL P>Q
390 NEXT R
400 END
