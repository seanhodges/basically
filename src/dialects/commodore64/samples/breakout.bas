10 REM BREAKOUT
20 POKE 53280,0:POKE 53281,0
30 POKE 54296,15:POKE 54277,9:POKE 54278,0
40 POKE 650,255
50 PRINT CHR$(147);CHR$(5)
60 PRINT:PRINT "       *** BREAKOUT ***"
70 PRINT:PRINT CHR$(158);"   1. KEYBOARD"
80 PRINT CHR$(154);"   2. JOYSTICK (PORT 2)"
90 GOSUB 700
100 MD=1
110 GET K$:IF K$="" THEN 110
120 IF K$="2" THEN MD=2
130 PRINT CHR$(147)
140 SC=1024:CM=55296:CO=CM-SC
150 NB=0:PR=24:PX=18
160 FOR R=2 TO 4
170 FOR C=5 TO 34
180 P=SC+40*R+C:POKE P,160:POKE P+CO,R
190 NB=NB+1
200 NEXT C:NEXT R
210 GOSUB 500
215 IF MD=1 THEN PRINT CHR$(19);"A D TO MOVE      "
217 IF MD=2 THEN PRINT CHR$(19);"JOYSTICK PORT 2  "
220 BX=20:BY=12:VX=1:VY=-1:S=0
230 GOSUB 400
240 IF LF AND PX>0 THEN GOSUB 520:PX=PX-2:GOSUB 500
250 IF RT AND PX<35 THEN GOSUB 520:PX=PX+2:GOSUB 500
260 POKE SC+40*BY+BX,32
270 NX=BX+VX:NY=BY+VY
280 IF NX<0 OR NX>39 THEN VX=-VX:NX=BX+VX:GOSUB 600
290 IF NY<1 THEN VY=-VY:NY=BY+VY:GOSUB 600
300 IF NY=PR-1 AND NX>=PX AND NX<=PX+4 THEN VY=-VY:NY=BY+VY:GOSUB 600
310 PT=SC+40*NY+NX
320 IF PEEK(PT)=160 THEN POKE PT,32:NB=NB-1:S=S+1:VY=-VY:NY=BY+VY:GOSUB 620
330 BX=NX:BY=NY
340 POKE SC+40*BY+BX,81:POKE SC+40*BY+BX+CO,1
350 FOR T=1 TO 60:NEXT
360 IF BY>=24 THEN 390
370 IF NB>0 THEN 230
380 PRINT CHR$(147);"YOU WIN  SCORE ";S:END
390 PRINT CHR$(147);"GAME OVER  SCORE ";S:GOSUB 650:END
400 REM READ INPUT
410 LF=0:RT=0
420 IF MD=1 THEN GET K$:IF (K$="A" OR K$="a") THEN LF=1
430 IF MD=1 AND (K$="D" OR K$="d") THEN RT=1
440 IF MD=2 THEN J=PEEK(56320):IF (J AND 4)=0 THEN LF=1
450 IF MD=2 AND (J AND 8)=0 THEN RT=1
460 RETURN
490 REM DRAW PADDLE
500 FOR I=0 TO 4:POKE SC+40*PR+PX+I,160:POKE SC+40*PR+PX+I+CO,1:NEXT:RETURN
515 REM ERASE PADDLE
520 FOR I=0 TO 4:POKE SC+40*PR+PX+I,32:NEXT:RETURN
600 REM LOW BEEP
605 POKE 54276,16:POKE 54273,10:POKE 54272,0:POKE 54276,17:RETURN
620 REM HIGH BEEP
625 POKE 54276,16:POKE 54273,40:POKE 54272,0:POKE 54276,17:RETURN
650 REM GAME OVER SLIDE
655 POKE 54278,240:POKE 54276,17
660 FOR F=50 TO 5 STEP -1:POKE 54273,F:FOR D=1 TO 12:NEXT D:NEXT F
665 POKE 54276,16:POKE 54278,0:RETURN
700 REM TITLE TUNE
710 POKE 54276,17
720 POKE 54273,17:FOR D=1 TO 90:NEXT
730 POKE 54273,25:FOR D=1 TO 90:NEXT
740 POKE 54273,33:FOR D=1 TO 90:NEXT
