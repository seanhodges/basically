10 REM BREAKOUT
20 POKE 53280,0:POKE 53281,0
30 PRINT CHR$(147)
40 SC=1024:CM=55296:CO=CM-SC
50 NB=0:PR=24:PX=18
60 FOR R=2 TO 4
70 FOR C=5 TO 34
80 P=SC+40*R+C:POKE P,160:POKE P+CO,R
90 NB=NB+1
100 NEXT C:NEXT R
110 GOSUB 500
120 BX=20:BY=12:VX=1:VY=1:S=0
130 GET K$
140 IF K$="Z" AND PX>0 THEN GOSUB 520:PX=PX-2:GOSUB 500
150 IF K$="X" AND PX<35 THEN GOSUB 520:PX=PX+2:GOSUB 500
160 POKE SC+40*BY+BX,32
170 NX=BX+VX:NY=BY+VY
180 IF NX<0 OR NX>39 THEN VX=-VX:NX=BX+VX
190 IF NY<1 THEN VY=-VY:NY=BY+VY
200 IF NY=PR-1 AND NX>=PX AND NX<=PX+4 THEN VY=-VY:NY=BY+VY
210 PT=SC+40*NY+NX
220 IF PEEK(PT)=160 THEN POKE PT,32:NB=NB-1:S=S+1:VY=-VY:NY=BY+VY
230 BX=NX:BY=NY
240 POKE SC+40*BY+BX,81:POKE SC+40*BY+BX+CO,1
250 FOR T=1 TO 40:NEXT
260 IF BY>=24 THEN 300
270 IF NB>0 THEN 130
280 PRINT CHR$(147);"YOU WIN  SCORE ";S
290 END
300 PRINT CHR$(147);"GAME OVER  SCORE ";S
310 END
500 FOR I=0 TO 4:POKE SC+40*PR+PX+I,160:POKE SC+40*PR+PX+I+CO,1:NEXT:RETURN
520 FOR I=0 TO 4:POKE SC+40*PR+PX+I,32:NEXT:RETURN
