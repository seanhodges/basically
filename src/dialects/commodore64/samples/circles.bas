10 REM CIRCLES - PETSCII COLOUR GRAPHICS
20 POKE 53280,0:POKE 53281,0
30 PRINT CHR$(147)
40 SC=1024:CM=55296:CO=CM-SC
50 CX=20:CY=12
60 CL=1
70 FOR R=3 TO 12 STEP 3
80 FOR A=0 TO 6.4 STEP 0.08
90 X=CX+R*COS(A):Y=CY+R*SIN(A)
100 IF X<0 OR X>39 OR Y<0 OR Y>24 THEN 130
110 P=SC+40*INT(Y+0.5)+INT(X+0.5)
120 POKE P,81:POKE P+CO,CL
130 NEXT A
140 CL=CL+1:IF CL>15 THEN CL=1
150 NEXT R
160 FOR T=1 TO 2000:NEXT
170 GOTO 30
