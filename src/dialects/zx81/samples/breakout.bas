10 REM BREAKOUT
20 LET X=15
30 LET BX=15
40 LET BY=5
50 LET DX=1
60 LET DY=1
70 LET S=0
80 CLS
90 FOR I=0 TO 31
100 PRINT AT 1,I;"▀"
110 NEXT I
120 PRINT AT 20,X;"▀▀▀▀"
125 REM GAME LOOP
130 PRINT AT BY,BX;"O"
140 LET K$=INKEY$
150 IF K$="5" AND X>0 THEN LET X=X-2
160 IF K$="8" AND X<28 THEN LET X=X+2
170 PRINT AT 20,0;"                                "
180 PRINT AT 20,X;"▀▀▀▀"
190 PRINT AT BY,BX;" "
200 LET BX=BX+DX
210 LET BY=BY+DY
220 IF BX<1 OR BX>30 THEN LET DX=-DX
230 IF BY<2 THEN LET DY=-DY
240 IF BY=2 THEN LET S=S+1
250 IF BY<19 THEN GOTO 130
260 IF BX>=X AND BX<=X+3 THEN LET DY=-DY
270 IF BY<21 THEN GOTO 130
280 PRINT AT 10,10;"GAME OVER"
290 PRINT AT 12,10;"SCORE ";S
300 PAUSE 300
310 RUN
