10 REM BREAKOUT
20 CLS
30 PRINT AT 5,12;"BREAKOUT"
40 PRINT AT 10,9;"PRESS ANY KEY"
50 IF INKEY$="" THEN GOTO 50
60 LET X=15
70 LET BX=15
80 LET BY=5
90 LET DX=1
100 LET DY=1
110 LET S=0
120 CLS
130 FOR I=0 TO 31
140 PRINT AT 1,I;"▀"
150 NEXT I
160 PRINT AT 0,0;"5 8 TO MOVE"
170 PRINT AT 20,X;"▀▀▀▀"
175 REM GAME LOOP
180 PRINT AT BY,BX;"O"
190 LET K$=INKEY$
200 IF K$="5" AND X>0 THEN LET X=X-2
210 IF K$="8" AND X<28 THEN LET X=X+2
220 PRINT AT 20,0;"                                "
230 PRINT AT 20,X;"▀▀▀▀"
240 PRINT AT BY,BX;" "
250 LET BX=BX+DX
260 LET BY=BY+DY
270 IF BX<1 OR BX>30 THEN LET DX=-DX
280 IF BY<2 THEN LET DY=-DY
290 IF BY=2 THEN LET S=S+1
300 IF BY<19 THEN GOTO 180
310 IF BX>=X AND BX<=X+3 THEN LET DY=-DY
320 IF BY<21 THEN GOTO 180
330 PRINT AT 10,10;"GAME OVER"
340 PRINT AT 12,10;"SCORE ";S
350 PAUSE 300
