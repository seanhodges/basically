10 REM BREAKOUT - A AND D MOVE THE PADDLE
20 CLS
30 NB=0
40 FOR Y=4 TO 8 STEP 4
50 FOR X=0 TO 120 STEP 8
60 FOR I=1 TO 6:SET(X+I,Y):SET(X+I,Y+1):NEXT
70 NB=NB+1
80 NEXT X:NEXT Y
90 PX=58:BX=64:BY=24:DX=1:DY=1:S=0
95 PRINT "A D TO MOVE";
100 FOR I=0 TO 11:SET(PX+I,46):NEXT
110 K$=INKEY$
120 IF K$="A" AND PX>0 THEN FOR I=0 TO 11:RESET(PX+I,46):NEXT:PX=PX-3:FOR I=0 TO 11:SET(PX+I,46):NEXT
130 IF K$="D" AND PX<116 THEN FOR I=0 TO 11:RESET(PX+I,46):NEXT:PX=PX+3:FOR I=0 TO 11:SET(PX+I,46):NEXT
140 RESET(BX,BY)
150 NX=BX+DX:NY=BY+DY
160 IF NX<1 OR NX>126 THEN DX=-DX:NX=BX+DX
170 IF NY<1 THEN DY=-DY:NY=BY+DY
180 IF NY<=9 AND POINT(NX,NY) THEN GOSUB 300
190 IF NY=45 AND NX>=PX AND NX<=PX+11 THEN DY=-1:NY=BY+DY
200 BX=NX:BY=NY
210 SET(BX,BY)
220 IF BY>46 THEN 250
230 IF NB=0 THEN 270
240 FOR T=1 TO 30:NEXT:GOTO 110
250 CLS:PRINT "GAME OVER  SCORE";S
260 END
270 CLS:PRINT "YOU WIN  SCORE";S
280 END
290 REM DESTROY THE BRICK THE BALL HIT
300 BC=INT(NX/8)*8
310 IF NY<6 THEN BR=4 ELSE BR=8
320 FOR I=1 TO 6:RESET(BC+I,BR):RESET(BC+I,BR+1):NEXT
330 NB=NB-1:S=S+1:DY=-DY:NY=BY+DY
340 RETURN
