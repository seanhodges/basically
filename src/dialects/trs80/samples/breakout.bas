10 REM BREAKOUT - A AND D MOVE THE PADDLE
20 CLS
30 PRINT
40 PRINT "          BREAKOUT"
50 PRINT
60 PRINT "       PRESS ANY KEY"
70 K$=INKEY$:IF K$="" THEN 70
80 CLS
90 NB=0
100 FOR Y=4 TO 8 STEP 4
110 FOR X=0 TO 120 STEP 8
120 FOR I=1 TO 6:SET(X+I,Y):SET(X+I,Y+1):NEXT
130 NB=NB+1
140 NEXT X:NEXT Y
150 PX=58:BX=64:BY=24:DX=1:DY=1:S=0
160 PRINT "A D TO MOVE";
170 FOR I=0 TO 11:SET(PX+I,46):NEXT
180 K$=INKEY$
190 IF K$="A" AND PX>0 THEN FOR I=0 TO 11:RESET(PX+I,46):NEXT:PX=PX-3:FOR I=0 TO 11:SET(PX+I,46):NEXT
200 IF K$="D" AND PX<116 THEN FOR I=0 TO 11:RESET(PX+I,46):NEXT:PX=PX+3:FOR I=0 TO 11:SET(PX+I,46):NEXT
210 RESET(BX,BY)
220 NX=BX+DX:NY=BY+DY
230 IF NX<1 OR NX>126 THEN DX=-DX:NX=BX+DX
240 IF NY<1 THEN DY=-DY:NY=BY+DY
250 IF NY<=9 AND POINT(NX,NY) THEN GOSUB 350
260 IF NY=45 AND NX>=PX AND NX<=PX+11 THEN DY=-1:NY=BY+DY
270 BX=NX:BY=NY
280 SET(BX,BY)
290 IF BY>46 THEN 320
300 IF NB=0 THEN 340
310 FOR T=1 TO 30:NEXT:GOTO 180
320 CLS:PRINT "GAME OVER  SCORE";S
330 END
340 CLS:PRINT "YOU WIN  SCORE";S
345 END
350 REM DESTROY THE BRICK THE BALL HIT
360 BC=INT(NX/8)*8
370 IF NY<6 THEN BR=4 ELSE BR=8
380 FOR I=1 TO 6:RESET(BC+I,BR):RESET(BC+I,BR+1):NEXT
390 NB=NB-1:S=S+1:DY=-DY:NY=BY+DY
400 RETURN
