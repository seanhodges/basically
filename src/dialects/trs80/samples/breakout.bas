10 REM BREAKOUT - PRESS , AND . TO MOVE THE PADDLE
20 CLS
30 PX=56:BX=64:BY=40:DX=1:DY=-1
40 REM DRAW A ROW OF BRICKS
50 FOR I=0 TO 124 STEP 4:SET(I,2):SET(I+1,2):NEXT
60 REM MAIN LOOP
70 K$=INKEY$
80 IF K$="," THEN PX=PX-4
90 IF K$="." THEN PX=PX+4
100 IF PX<0 THEN PX=0
110 IF PX>118 THEN PX=118
120 RESET(BX,BY)
130 BX=BX+DX:BY=BY+DY
140 IF BX<1 OR BX>126 THEN DX=-DX
150 IF BY<2 OR BY>44 THEN DY=-DY
160 SET(BX,BY)
170 FOR P=PX TO PX+8:SET(P,46):NEXT
180 GOTO 70
