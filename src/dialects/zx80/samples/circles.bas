10 REM CIRCLES
20 CLS
30 FOR Y=0 TO 21
40 FOR X=0 TO 31
50 LET A=X-16
60 LET B=(Y-11)*2
70 LET D=A*A+B*B
80 LET P=0
90 IF D>16 AND D<36 THEN LET P=1
100 IF D>84 AND D<118 THEN LET P=1
110 IF D>200 AND D<252 THEN LET P=1
120 IF P=1 THEN PRINT "O";
130 IF P=0 THEN PRINT " ";
140 NEXT X
150 PRINT
160 NEXT Y
170 FOR T=1 TO 4000
180 NEXT T
190 GOTO 20
