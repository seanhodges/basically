10 REM DODGER - AVOID THE BLOCKS
20 LET X=15
30 LET S=0
40 CLS
50 LET BX=INT (RND*32)
60 LET BY=0
70 LET K$=INKEY$
80 IF K$="5" AND X>0 THEN LET X=X-1
90 IF K$="8" AND X<31 THEN LET X=X+1
100 PRINT AT BY,BX;" "
110 LET BY=BY+1
120 PRINT AT BY,BX;"█"
130 PRINT AT 21,0;"                                "
140 PRINT AT 21,X;"▀"
150 IF BY=21 AND BX=X THEN GOTO 200
160 IF BY<21 THEN GOTO 70
170 PRINT AT BY,BX;" "
180 LET S=S+1
190 GOTO 50
200 PRINT AT 10,10;"CRASHED"
210 PRINT AT 12,12;"SCORE ";S
220 PAUSE 300
230 RUN
